{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Congmiao Toolbox",
  "version": "0.1.2",
  "identifier": "com.tenonsuzu.congmiao-toolbox",
  "build": {
    "beforeDevCommand": "bun run tauri:icon && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run tauri:icon && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Congmiao Toolbox",
        "width": 1366,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBOUVCRDBFQzlEQTFFMkQKUldRdEh0ckpEcjJlaW11T0xiNFkzV0I0dFdTd3Nvbm5Sd1A4KytjbG93SVZhTnJxakJ4bXRzUXAK",
      "endpoints": [
        "https://github.com/YoisakiKnd/congmiao-toolbox/releases/latest/download/latest.json"
      ]
    }
  }
}
